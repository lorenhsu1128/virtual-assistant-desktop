{
  "name": "virtual-assistant-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:1420 && electron .\"",
    "dev:vite": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "package": "bun run build && electron-builder",
    "package:win": "bun run build && electron-builder --win",
    "package:mac": "bun run build && electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ tests/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"electron/**/*.ts\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "scan:expressions": "node scripts/scan-vrm-expressions.mjs",
    "build:vendor": "cd vendor/my-agent && bun install && bun run build:embedded",
    "postinstall": "node scripts/postinstall-vendor.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pixiv/three-vrm": "^3.4.0",
    "@pixiv/three-vrm-animation": "^3.4.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ikts": "^1.3.7",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.172.0",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.20.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "trustedDependencies": [
    "electron",
    "electron-winstaller",
    "esbuild",
    "koffi",
    "uiohook-napi"
  ],
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.172.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.0",
    "koffi": "^2.9.3",
    "postcss": "^8.5.14",
    "prettier": "^3.5.3",
    "tailwindcss": "^3",
    "typescript": "^5.8.3",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "wait-on": "^8.0.3"
  }
}
